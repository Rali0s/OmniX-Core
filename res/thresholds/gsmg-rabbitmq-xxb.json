        "decision": "recommend_runbook",
        "recommendation": "Restart abc-worker.service, then validate consumer reconnect and queue drain.",
        "runbookId": "restart-abc-worker",
        "escalationRequired": false,
        "rationale": "RAM, queue depth trend, consumer count, and signature EYZ-47281 meet the generic app-worker exhaustion boundary."
      }
    },
    {
      "id": "safe-worker-restart-boundary",
      "description": "Restart is permitted only when broker health, persistence, consumer loss, and packet-loss risk are acceptable.",
      "if": [
        { "signal": "rabbitmq.node.health", "status": "healthy" },
        { "signal": "message.persistence", "status": "persistent" },
        { "signal": "consumer.count", "operator": "==", "value": 0 },
        { "signal": "restart.loss.estimate", "operator": "<=", "value": 3 }
      ],
      "then": {
        "likelyCause": "runbook_allowed_low_loss_restart",
        "severity": "abnormal",
        "decision": "recommend_runbook",
        "recommendation": "Run the restart only after operator review; collect before/after consumer count and queue depth.",
        "runbookId": "restart-abc-worker",
        "escalationRequired": false,
        "rationale": "The action boundary is satisfied without assuming the RabbitMQ node is the cause."
      }
    }
  ],
  "runbooks": [
    {
      "id": "restart-abc-worker",
      "type": "systemd_restart_service",
      "target": "abc-worker.service",
      "displayCommand": "sudo systemctl restart abc-worker.service",
      "validationChecks": [
