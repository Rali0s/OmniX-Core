  "policies": [
    {
      "id": "data-loss-guard.database-shutdown-blocked",
      "description": "Database shutdown is blocked while client writes, app connection pools, active DB writers, queue acknowledgements, or mount writers still exist.",
      "if": [
        { "signal": "ingress.external_writes.active", "operator": ">", "value": 0 },
        { "signal": "connection_pool.open", "operator": ">", "value": 0 },
        { "signal": "database.active_writers", "operator": ">", "value": 0 },
        { "signal": "queue.unacked", "operator": ">", "value": 0 },
        { "signal": "mount.active_writers", "operator": ">", "value": 0 }
      ],
      "then": {
        "likelyCause": "unsafe_database_shutdown_path",
        "severity": "blocker",
        "decision": "block_unsafe_action",
        "recommendation": "Do not stop the database. Quiesce ingress, drain app sessions, stop producers, drain queues, close connection pools, then re-evaluate.",
        "runbookId": "controlled-shutdown-preflight",
        "escalationRequired": true,
        "rationale": "Outage-window doctrine says the data core must not be stopped while front door, app writers, queues, or mounts are still active."
      }
    },
    {
      "id": "sensor-mute-safe-scope",
      "description": "Scheduled maintenance may mute internal sensors, but client-impact and data-loss indicators remain active.",
      "if": [
        { "signal": "maintenance.window.approved", "status": "approved" },
        { "signal": "sensor.mute.scope", "status": "internal_only" }
      ],
      "then": {
        "likelyCause": "controlled_maintenance_alarm_suppression",
        "severity": "warning",
        "decision": "continue_preflight",
        "recommendation": "Proceed only with controlled internal sensor muting; keep client-impact, corruption, replication, and data-loss alarms active.",
        "runbookId": "controlled-shutdown-preflight",
        "escalationRequired": false,
        "rationale": "Controlled muting prevents alarm storms without silencing reality."
      }
    }
  ],
  "runbooks": [
    {
      "id": "controlled-shutdown-preflight",
      "type": "recommendation_only",
      "target": "maintenance-window",
      "displayCommand": "quiesce ingress -> drain queues -> stop apps -> close pools -> stop DB -> flush/unmount -> detach storage",
      "validationChecks": [
        "external writes are zero",
        "connection pools are closed",
        "queue unacked count is zero",
        "database active writers are zero",
        "mount active writers are zero",
        "backup checkpoint is valid"
      ]
    }
  ],
  "doctrineNotes": [
    "Outage windows are threshold problems in reverse: the system must prove it is safe to intentionally stop each layer.",
    "Shutdown order is ingress, application, queue/message, data, storage, host; startup is the reverse order.",
    "Database and storage actions are blocked until writes, pools, queues, and mount activity are quiesced."
  ]
}
